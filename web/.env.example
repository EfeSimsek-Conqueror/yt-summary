# =============================================================================
# Local setup: copy this file to `.env.local` (same folder as package.json) and
# fill values. Never commit `.env.local`.
#
# Railway → Variables: copy each key/value into `.env.local`. For **local dev**,
# set `NEXT_PUBLIC_APP_URL` or `NEXT_PUBLIC_SITE_URL` to http://localhost:3000
# (not production https://vidsum.ai) so OAuth redirects stay on your machine.
# =============================================================================

# Supabase — Project Settings → API (or paste from Railway)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (alias of NEXT_PUBLIC_APP_URL). Local dev:
#   NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production / Railway often mirrors:
#   NEXT_PUBLIC_SITE_URL=https://vidsum.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional (metadata / server fallbacks). OAuth redirect in the browser ignores
# this and always uses the current tab URL — do NOT set to vidsum.ai for local dev.
# Either name works (alias): NEXT_PUBLIC_APP_URL or NEXT_PUBLIC_SITE_URL
#
# Your **Next.js** deploy URL (VidSum web). NOT the Python “YouTube Analyzer” API.
# Production:
#   NEXT_PUBLIC_APP_URL=https://vidsum.ai
# Preview / alternate host only:
#   NEXT_PUBLIC_APP_URL=https://your-next-service.up.railway.app
# NEXT_PUBLIC_APP_URL=
#
# Optional: separate Python FastAPI service (health JSON at GET /).
# Server-only alias: ANALYZER_API_URL (same value, not bundled to the client).
#   NEXT_PUBLIC_ANALYZER_API_URL=https://youtube-analyzer-production-xxxx.up.railway.app
# ANALYZER_API_URL=
#
# Supabase → Redirect URLs must include every origin you use, e.g.:
#   http://localhost:3000/oauth/return
#   http://127.0.0.1:3000/oauth/return

# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: same as NEXT_PUBLIC_APP_URL (e.g. Railway URL or https://vidsum.ai)
#   Redirect URLs: ${SITE_URL}/oauth/return AND http://localhost:3000/oauth/return (dev)
#   Legacy /auth/callback still redirects to /oauth/return.
#   Dev Site URL can stay http://localhost:3000 when testing locally.
#
# If sign-in still sends you to the wrong port, force the app origin:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Google provider: enable + paste OAuth Client ID/Secret from Google Cloud Console
#
# Same Web client as Supabase → Authentication → Google (for refresh-token exchange after
# JWT refresh drops provider_token). Required for YouTube subs/search after page refresh.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
#
# YouTube subscriptions: enable "YouTube Data API v3" in Google Cloud → APIs & Services.
# OAuth consent screen → add scope: ../auth/youtube.readonly
# After changing scopes, user must sign out and sign in again.

# Discover hub (`/dashboard/discover`): set to "true" to enable category searches
# (uses YouTube Data API quota). Omit or "false" shows Coming soon only.
# NEXT_PUBLIC_DISCOVER_ENABLED=true

# =============================================================================
# Railway “service variables” (paste from dashboard; names match common deploys)
# =============================================================================

# YouTube Data API v3 (comments, search, etc.)
# YOUTUBE_DATA_API_KEY=

# Set in Railway if your stack uses YouTube OAuth features; safe to omit locally if unused.
# YOUTUBE_OAUTH2=true

# Fal.ai (video analysis pipeline)
# FAL_KEY=

# Deepgram (if used by a worker or future feature — not referenced in web/ yet)
# DEEPGRAM_API_KEY=

# Supadata transcripts — https://supadata.ai
# SUPADATA_API_KEY=

# Optional: top comments on the video page (YouTube Data API v3 commentThreads).
# Not the same as GEMINI_API_KEY—create a browser/server key with YouTube Data API v3 enabled.
# YOUTUBE_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_CLOUD_API_KEY=

# AI analysis (POST /api/ai/video-analysis): summary/segments use Gemini via Fal → OpenRouter.
# Get a key: https://fal.ai/dashboard → API Keys.
# Local: uncomment and set in web/.env.local (never commit .env.local).
# Production (Railway/Vercel): add variable name FAL_KEY in the dashboard — do not put the value in git.
# Never use NEXT_PUBLIC_ for this key.
# FAL_KEY=

# Transcripts (POST /api/ai/video-analysis): Supadata — https://supadata.ai
# Railway: SUPADATA_API_KEY (x-api-key). Alias also accepted: SUPADATA_KEY.
# Never commit real keys; rotate in dashboard if leaked.
# Optional: SUPADATA_LANG=en — use auto|native|generate if you override mode (default native; use auto when captions missing).
# SUPADATA_API_KEY=
# SUPADATA_LANG=
# SUPADATA_TRANSCRIPT_MODE=native

# Optional: when set, no-caption transcription uses the Gemini API directly (YouTube URL).
# If unset, transcription falls back to the same FAL video router as before (FAL_KEY only).
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash

# No-caption path: if AI speech-density score is below this (0–100), run visual analysis too. Default 40.
# VIDSUM_VISUAL_DENSITY_THRESHOLD=40
# Optional override for visual-only Gemini model (defaults to gemini-2.5-flash).
# GEMINI_VISUAL_MODEL=gemini-2.5-flash

# Stripe (billing) — Checkout + Customer Portal + webhooks:
# https://dashboard.stripe.com/apikeys
# Create Products/Prices for Navigator ($12/mo) and Captain ($25/mo), recurring monthly.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Signing secret from Developers → Webhooks
# STRIPE_PRICE_ID_NAVIGATOR=price_...
# STRIPE_PRICE_ID_CAPTAIN=price_...
# SUPABASE_SERVICE_ROLE_KEY=...     # Server-only: Stripe webhooks + stripe_customers writes (never in client)
#
# Fiyat ID’lerini listelemek (MCP ile aynı secret key):
#   cd web && STRIPE_SECRET_KEY=sk_test_... npm run stripe:prices
# veya: node --env-file=.env.local ./scripts/stripe-list-prices.mjs
