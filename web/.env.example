# Copy to .env.local — get values from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard → Authentication → URL Configuration:
#   Redirect URLs: http://localhost:3000/auth/callback
#   Site URL: http://localhost:3000 (dev)
# Google provider: enable + paste OAuth Client ID/Secret from Google Cloud Console
#
# YouTube subscriptions: enable "YouTube Data API v3" in Google Cloud → APIs & Services.
# OAuth consent screen → add scope: ../auth/youtube.readonly
# After changing scopes, user must sign out and sign in again.

# AI analysis (POST /api/ai/video-analysis): summary/segments use Gemini via Fal → OpenRouter.
# Get a key: https://fal.ai/dashboard → API Keys.
# Local: uncomment and set in web/.env.local (never commit .env.local).
# Production (Railway/Vercel): add variable name FAL_KEY in the dashboard — do not put the value in git.
# Never use NEXT_PUBLIC_ for this key.
# FAL_KEY=

# Optional: when set, no-caption transcription uses the Gemini API directly (YouTube URL).
# If unset, transcription falls back to the same FAL video router as before (FAL_KEY only).
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
