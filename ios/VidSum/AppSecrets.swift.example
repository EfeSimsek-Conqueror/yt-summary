import Foundation

/// Copy to `AppSecrets.swift` and set values from `web/.env.local`.
/// Command: `cp VidSum/AppSecrets.swift.example VidSum/AppSecrets.swift`
enum AppSecrets {
  static let supabaseURL = URL(string: "https://YOUR_PROJECT_REF.supabase.co")!
  static let supabaseAnonKey = "YOUR_SUPABASE_ANON_KEY"
}
