# Copy to .env.local — get values from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard → Authentication → URL Configuration:
#   Redirect URLs: http://localhost:3000/auth/callback
#   Site URL: http://localhost:3000 (dev)
# Google provider: enable + paste OAuth Client ID/Secret from Google Cloud Console
#
# YouTube subscriptions: enable "YouTube Data API v3" in Google Cloud → APIs & Services.
# OAuth consent screen → add scope: ../auth/youtube.readonly
# After changing scopes, user must sign out and sign in again.

# AI analysis (required for “Load transcript & analyze” and POST /api/ai/*).
# Get a key: https://fal.ai/dashboard → API Keys. Put it ONLY in web/.env.local (this folder),
# then restart `npm run dev` / redeploy. Never use NEXT_PUBLIC_ — the key must stay server-side.
# FAL_KEY=
